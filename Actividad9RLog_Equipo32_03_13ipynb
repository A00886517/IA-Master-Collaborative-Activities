        "                ha='center', va='center',\n",
        "                xytext=(0, 9),\n",
        "                textcoords='offset points')\n",
        "\n",
        "plt.title('Distribución Porcentual de Diagnosis (M=Maligno, B=Benigno)')\n",
        "plt.ylabel('Porcentaje (%)')\n",
